groups:
- name: node.rules
  rules:
    # CPU Usage
    - record: instance:node_cpu_usage:rate5m
      expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100
    
    # Memory Usage
    - record: instance:node_memory_usage:ratio
      expr: (node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100
    
    # Disk Space Usage
    - record: instance:node_filesystem_usage:ratio
      expr: (node_filesystem_size_bytes{mountpoint="/"} - node_filesystem_avail_bytes{mountpoint="/"}) / node_filesystem_size_bytes{mountpoint="/"} * 100
    
    # Network Traffic
    - record: instance:node_network_receive_bytes:rate5m
      expr: rate(node_network_receive_bytes_total[5m])
    - record: instance:node_network_transmit_bytes:rate5m
      expr: rate(node_network_transmit_bytes_total[5m])

- name: container.rules
  rules:
    # Container CPU Usage
    - record: container_cpu_usage_seconds_total:rate5m
      expr: rate(container_cpu_usage_seconds_total[5m])
    
    # Container Memory Usage
    - record: container_memory_usage_bytes
      expr: container_memory_usage_bytes
    
    # Container Restarts
    - record: container_last_seen
      expr: time() - container_last_seen

- name: docker.rules
  rules:
    # Container States
    - record: docker_containers_state
      expr: count by(state) (container_last_seen)
    
    # Image Pulls
    - record: docker_image_pulls:rate5m
      expr: rate(docker_image_pulls_total[5m])

- name: traefik.rules
  rules:
    # Request Rate
    - record: traefik_requests_total:rate5m
      expr: rate(traefik_requests_total[5m])
    
    # Error Rate
    - record: traefik_requests_errors:rate5m
      expr: sum by(code) (rate(traefik_requests_total{code=~"5.."}[5m]))

- name: postgres.rules
  rules:
    # Connection Usage
    - record: postgres_connections_used:ratio
      expr: pg_stat_activity_count / pg_settings_max_connections * 100
    
    # Cache Hit Ratio
    - record: postgres_cache_hit_ratio
      expr: (1 - (pg_stat_database_blk_read / (pg_stat_database_blk_hit + pg_stat_database_blk_read))) * 100

- name: redis.rules
  rules:
    # Memory Usage
    - record: redis_memory_usage_ratio
      expr: redis_memory_used_bytes / redis_memory_max_bytes * 100
    
    # Hit Rate
    - record: redis_hit_rate
      expr: redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total) * 100

- name: blackbox.rules
  rules:
    # Uptime
    - record: probe_success
      expr: probe_success
    
    # Response Time
    - record: probe_duration_seconds
      expr: probe_duration_seconds

- name: business.rules
  rules:
    # Application Specific Metrics
    - record: app_http_requests_total:rate5m
      expr: rate(http_requests_total[5m])
    
    # Error Budget
    - record: app_error_budget_remaining
      expr: (1 - (sum(rate(http_requests_total{status=~"5.."}[1h])) / sum(rate(http_requests_total[1h])))) * 100
