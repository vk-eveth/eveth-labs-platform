  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Overall CPU usage across all containers",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "8.3.4",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total[1m])) by (container_label_com_docker_swarm_service_name) * 100 / count(node_cpu_seconds_total{mode=\"system\"}) by (container_label_com_docker_swarm_service_name)",
          "legendFormat": "{{container_label_com_docker_swarm_service_name}}",
          "refId": "A"
        }
      ],
      "title": "Container CPU Usage",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "description": "Memory usage across all containers",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "8.3.4",
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{container_label_com_docker_swarm_service_name=~\".+\"}) by (container_label_com_docker_swarm_service_name)",
          "legendFormat": "{{container_label_com_docker_swarm_service_name}}",
          "refId": "A"
        }
      ],
      "title": "Container Memory Usage",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "description": "Network I/O across all containers",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total[1m])) by (container_label_com_docker_swarm_service_name)",
          "legendFormat": "{{container_label_com_docker_swarm_service_name}} (RX)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total[1m])) by (container_label_com_docker_swarm_service_name)",
          "legendFormat": "{{container_label_com_docker_swarm_service_name}} (TX)",
          "refId": "B"
        }
      ],
      "title": "Network I/O",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Container restarts in the last hour",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "pluginVersion": "8.3.4",
      "targets": [
        {
          "expr": "sum(increase(container_last_seen[1h])) by (container_label_com_docker_swarm_service_name)",
          "legendFormat": "{{container_label_com_docker_swarm_service_name}}",
          "refId": "A"
        }
      ],
      "title": "Container Restarts (1h)",
      "type": "stat"
    }
  ],
