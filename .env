# Domain Configuration
DOMAIN=evethlabstech

# Traefik Configuration
TRAEFIK_DASHBOARD_DOMAIN=traefik.${DOMAIN}
ACME_EMAIL=admin@${DOMAIN}

# Service Domains
GITLAB_DOMAIN=gitlab.${DOMAIN}
SONARQUBE_DOMAIN=sonar.${DOMAIN}
GRAFANA_DOMAIN=grafana.${DOMAIN}
PROMETHEUS_DOMAIN=prometheus.${DOMAIN}
LOKI_DOMAIN=loki.${DOMAIN}
PORTAINER_DOMAIN=portainer.${DOMAIN}
ALERTMANAGER_DOMAIN=alertmanager.${DOMAIN}
HARBOR_DOMAIN=harbor.${DOMAIN}

# Security (CHANGE THESE IN PRODUCTION!)
# Traefik Basic Auth (user:hashed_password)
# Generate with: docker run --rm httpd:2.4-alpine htpasswd -nb admin YourPassword
TRAEFIK_AUTH=admin:$$apr1$$qiNHN8Yd$$MF0EdB9.QJ0HltNUDTJAZ1


# GitLab
GITLAB_ROOT_PASSWORD=ChangeMe123!
GITLAB_SSH_PORT=2222

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMe123!

# Harbor
HARBOR_ADMIN_PASSWORD=ChangeMe123!
HARBOR_DB_PASSWORD=harbor_db_ChangeMe123!

# SonarQube Database
SONAR_JDBC_PASSWORD=sonar

# Redis
REDIS_PASSWORD=redis_secure_pass_2024

# Alerting
SMTP_SERVER=smtp.gmail.com:587
ALERT_EMAIL_FROM=alerts@${DOMAIN}
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# SLACK_WEBHOOK_URL=your-slack-webhook-url

# Service Versions
TRAEFIK_VERSION=2.11.2
GITLAB_VERSION=15.11.0-ce.0
SONARQUBE_VERSION=9.9.0-community
POSTGRES_VERSION=13
REDIS_VERSION=7
GRAFANA_VERSION=9.3.2
PROMETHEUS_VERSION=v2.40.0
LOKI_VERSION=2.7.3
PORTAINER_VERSION=2.16.2
HARBOR_VERSION=2.10.0
ALERTMANAGER_VERSION=v0.26.0

# Harbor install directory (generated by prepare)
HARBOR_INSTALL_DIR=/opt/harbor/harbor

# Resource Limits (adjust based on your system)
MEMORY_LIMIT=8G
CPU_LIMIT=4.0

# Ports (for direct access if needed)
TRAEFIK_WEB_PORT=80
TRAEFIK_WEB_SECURE_PORT=443
TRAEFIK_DASHBOARD_PORT=8080


# Storage Paths
DATA_PATH=./data
CONFIG_PATH=./config
BACKUP_PATH=./backups
LOG_PATH=./logs
