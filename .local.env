#########################################
# Domain Configuration
#########################################

# Replace with your own domain
DOMAIN=example.com

#########################################
# Traefik Configuration
#########################################

TRAEFIK_DASHBOARD_DOMAIN=traefik.${DOMAIN}

# Email used for Let's Encrypt certificates
ACME_EMAIL=admin@example.com

#########################################
# Service Domains
#########################################

GITLAB_DOMAIN=gitlab.${DOMAIN}
SONARQUBE_DOMAIN=sonar.${DOMAIN}
GRAFANA_DOMAIN=grafana.${DOMAIN}
PROMETHEUS_DOMAIN=prometheus.${DOMAIN}
LOKI_DOMAIN=loki.${DOMAIN}
PORTAINER_DOMAIN=portainer.${DOMAIN}
ALERTMANAGER_DOMAIN=alertmanager.${DOMAIN}
HARBOR_DOMAIN=harbor.${DOMAIN}

#########################################
# Security
#########################################

# Generate with:
# docker run --rm httpd:2.4-alpine htpasswd -nb admin YourPassword

TRAEFIK_AUTH=admin:<GENERATED_HTPASSWD_HASH>

#########################################
# GitLab
#########################################

GITLAB_ROOT_PASSWORD=<CHANGE_ME>
GITLAB_SSH_PORT=2222

#########################################
# Grafana
#########################################

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME>

#########################################
# Harbor
#########################################

HARBOR_ADMIN_PASSWORD=<CHANGE_ME>
HARBOR_DB_PASSWORD=<CHANGE_ME>

#########################################
# SonarQube Database
#########################################

SONAR_JDBC_PASSWORD=<CHANGE_ME>

#########################################
# Redis
#########################################

REDIS_PASSWORD=<CHANGE_ME>

#########################################
# Alerting
#########################################

SMTP_SERVER=smtp.example.com:587
ALERT_EMAIL_FROM=alerts@${DOMAIN}
SMTP_USER=your-email@example.com
SMTP_PASSWORD=<SMTP_APP_PASSWORD>

# Optional
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXX/XXXXXXXXXXXXXXXX

#########################################
# Service Versions
#########################################

TRAEFIK_VERSION=2.11.2
GITLAB_VERSION=15.11.0-ce.0
SONARQUBE_VERSION=9.9.0-community
POSTGRES_VERSION=13
REDIS_VERSION=7
GRAFANA_VERSION=9.3.2
PROMETHEUS_VERSION=v2.40.0
LOKI_VERSION=2.7.3
PORTAINER_VERSION=2.16.2
HARBOR_VERSION=2.10.0
ALERTMANAGER_VERSION=v0.26.0

#########################################
# Harbor Installation
#########################################

HARBOR_INSTALL_DIR=/opt/harbor/harbor

#########################################
# Resource Limits
#########################################

MEMORY_LIMIT=8G
CPU_LIMIT=4.0

#########################################
# Network Ports
#########################################

TRAEFIK_WEB_PORT=80
TRAEFIK_WEB_SECURE_PORT=443
TRAEFIK_DASHBOARD_PORT=8080

#########################################
# Storage Paths
#########################################

DATA_PATH=./data
CONFIG_PATH=./config
BACKUP_PATH=./backups
LOG_PATH=./logs
